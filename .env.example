# Site Configuration
NEXT_PUBLIC_SITE_URL=https://innovista.design

# Sanity CMS Configuration
# Get these values from sanity.io/manage
SANITY_PROJECT_ID=your-project-id-here
SANITY_DATASET=production

# For Sanity Studio
SANITY_STUDIO_PROJECT_ID=your-project-id-here
SANITY_STUDIO_DATASET=production

# Optional: Gemini API (if using AI features)
GEMINI_API_KEY=your-gemini-api-key

# Resend Email Service (for contact/audit forms)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
